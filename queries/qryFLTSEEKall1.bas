    Expression ="FLTSEEK.MAINTENANCE"
    Alias ="ScoreCredit"
    Expression ="IIf([FLTSEEK]![CREDITTYPE] Is Null,\"MissingData\",IIf([FLTSEEK]![CREDITTYPE]=\""
        "Investment Grade\",25,IIf([FLTSEEK]![CREDITTYPE]=\"Privately Held\",10,IIf([FLTS"
        "EEK]![CREDITTYPE]=\"Less Than Investment Grade\",0,0))))"
    Alias ="ScoreCredit2"
    Expression ="IIf([FLTSEEK]![FACREDITRANK]=\"1\" And [FLTSEEK]![CREDITTYPE]=\"Privately Held\""
        ",15,IIf([FLTSEEK]![FACREDITRANK]=\"2\" And [FLTSEEK]![CREDITTYPE]=\"Privately He"
        "ld\",15,IIf([FLTSEEK]![FACREDITRANK]=\"3\" And [FLTSEEK]![CREDITTYPE]=\"Privatel"
        "y Held\",15,IIf([FLTSEEK]![FACREDITRANK]=\"4\" And [FLTSEEK]![CREDITTYPE]=\"Priv"
        "ately Held\",15,IIf([FLTSEEK]![FACREDITRANK]=\"1\",10,IIf([FLTSEEK]![FACREDITRAN"
        "K]=\"2\",10,IIf([FLTSEEK]![FACREDITRANK]=\"3\",10,IIf([FLTSEEK]![FACREDITRANK]=\""
        "4\",10,0))))))))"
    Alias ="ScoreFleetSize"
    Expression ="IIf([FleetSize] Is Null,\"MissingData\",IIf([FleetSize]>=200,15,0))"
    Alias ="FleetSize"
    Expression ="[FLTSEEK]![NUMBERDAYCABS]+[FLTSEEK]![NUMBERSLEEPERS]"
    Alias ="PercentDC"
    Expression ="[FLTSEEK]![NUMBERDAYCABS]/([FLTSEEK]![NUMBERDAYCABS]+[FLTSEEK]![NUMBERSLEEPERS])"
    Alias ="ScorePercentDC"
    Expression ="IIf([PercentDC] Is Null,\"Missing Data\",IIf([PercentDC]>=0.7,15,IIf([PercentDC]"
        ">=0.5,10,0)))"
    Alias ="ScoreDCMiles"
    Expression ="IIf([FLTSEEK]![MPYDAYCAB]<80000 Or [FLTSEEK]![MPYDAYCAB]>120000,-10,IIf([FLTSEEK"
        "]![MPYDAYCAB] Is Null,\"MissingData\",0))"
    Alias ="ScoreSLMiles"
    Expression ="IIf([FLTSEEK]![MPYSLEEPER] Is Null,\"MissingData\",IIf([FLTSEEK]![MPYSLEEPER]>13"
        "0000,-10,0))"
    Alias ="ScoreMAINTENANCE"
    Expression ="IIf([FLTSEEK]![MAINTENANCE] Is Null,\"MissingData\",IIf([FLTSEEK]![MAINTENANCE]="
        "\"In House\",15,IIf([FLTSEEK]![MAINTENANCE]=\"3rd Party\",10,0)))"
    Alias ="ScoreLIFECYCLE"
    Expression ="IIf([FLTSEEK]![LIFECYCLE] Is Null,\"MissingData\",IIf([FLTSEEK]![LIFECYCLE]>=5,1"
        "5,0))"
    Alias ="ScoreACQUISITION"
    Expression ="IIf([ACQUISITIONMODE] Is Null,\"MissingData\",IIf([ACQUISITIONMODE]=\"Purchase\""
        ",15,IIf([ACQUISITIONMODE]=\"Lease\",10,IIf([ACQUISITIONMODE]=\"Full\",-10,0))))"
    Alias ="TOTALSCORE"
    Expression ="[ScoreCredit]+[ScoreCredit2]+[ScoreFleetSize]+[ScorePercentDC]+[ScoreDCMiles]+[S"
        "coreSLMiles]+[ScoreMaintenance]+[ScoreLifecycle]+[ScoreAcquisition]"
    Alias ="GRADE"
    Expression ="IIf([TOTALSCORE]>=80,\"Qualifies\",IIf([TOTALSCORE]>=70,\"Review Required\",\"Do"
        "es Not Qualify\"))"
